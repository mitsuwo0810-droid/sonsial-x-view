APP_NAME=sonsial x view

# X/Twitterログイン情報（APIキーは不要です）
TWIKIT_USERNAME=your_x_username
TWIKIT_EMAIL=your_email@example.com
TWIKIT_PASSWORD=your_password
TWIKIT_TOTP_SECRET=
TWIKIT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36

# Twikit / 表示設定
TWIKIT_LANGUAGE=ja-JP
TWIKIT_COOKIE_FILE=data/cookies.json
CACHE_TTL_SECONDS=120
REQUEST_MIN_INTERVAL_SECONDS=2.0
RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=1.5
REQUEST_TIMEOUT_SECONDS=30
TWEET_COUNT=20
DEFAULT_TIMELINE=latest
