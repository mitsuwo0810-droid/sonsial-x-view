APP_NAME=sonsial x view

# X/Twitterログイン情報（APIキーは不要です）
TWIKIT_USERNAME=your_x_username
TWIKIT_EMAIL=your_email@example.com
TWIKIT_PASSWORD=your_password
TWIKIT_TOTP_SECRET=
TWIKIT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/148.0.0.0 Safari/537.36
BROWSER_ACCEPT_LANGUAGE=ja-JP,ja;q=0.9,en-US;q=0.8,en;q=0.7
BROWSER_REFERER=https://x.com/home

# Twikit / 表示設定
TWIKIT_LANGUAGE=ja-JP
TWIKIT_COOKIE_FILE=data/cookies.json
CACHE_TTL_SECONDS=120
REQUEST_MIN_INTERVAL_SECONDS=2.0
REQUEST_JITTER_SECONDS=1.5
RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=1.5
RETRY_BACKOFF_JITTER_SECONDS=1.0
REQUEST_TIMEOUT_SECONDS=30
TIMELINE_SLEEP_MIN_SECONDS=0.8
TIMELINE_SLEEP_MAX_SECONDS=2.4
TWIKIT_TRANSACTION_MODE=auto
REFRESH_TRANSACTION_BEFORE_TIMELINE=true
TWEET_COUNT=20
DEFAULT_TIMELINE=latest
